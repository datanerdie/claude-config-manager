---
const kinds = [
  {
    name: "Agents",
    blurb: "Specialized Claude personas with their own prompt, tools, and model.",
    icon: `<path d="M12 3a4 4 0 100 8 4 4 0 000-8zM4 21a8 8 0 1116 0" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>`,
  },
  {
    name: "Commands",
    blurb: "Slash-command shortcuts that invoke Claude with preset context.",
    icon: `<path d="M7 8l-3 4 3 4M17 8l3 4-3 4M14 4l-4 16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  {
    name: "Skills",
    blurb: "Reusable knowledge modules agents and commands can pull in.",
    icon: `<path d="M12 3l2.6 5.3 5.9.9-4.3 4.1 1 5.8L12 16.5 6.8 19.1l1-5.8L3.5 9.2l5.9-.9L12 3z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>`,
  },
  {
    name: "Rules",
    blurb: "Path-based policies that govern what Claude can do where.",
    icon: `<path d="M4 6h16M4 12h16M4 18h16M8 4v4M16 10v4M10 16v4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>`,
  },
  {
    name: "Hooks",
    blurb: "Event triggers fired on tool use, session start, and more.",
    icon: `<path d="M12 3v10m0 0a4 4 0 104 4M12 13a4 4 0 01-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>`,
  },
  {
    name: "MCP Servers",
    blurb: "Model Context Protocol integrations — stdio, SSE, or HTTP.",
    icon: `<rect x="3" y="5" width="18" height="5" rx="1.5" stroke="currentColor" stroke-width="1.6"/><rect x="3" y="14" width="18" height="5" rx="1.5" stroke="currentColor" stroke-width="1.6"/><circle cx="7" cy="7.5" r="0.8" fill="currentColor"/><circle cx="7" cy="16.5" r="0.8" fill="currentColor"/>`,
  },
  {
    name: "CLAUDE.md",
    blurb: "Project-wide instructions that travel with your codebase.",
    icon: `<path d="M6 3h9l3 3v15H6V3z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M15 3v3h3M9 13h6M9 17h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>`,
  },
  {
    name: "Memory",
    blurb: "Persistent project context — what Claude remembers between sessions.",
    icon: `<path d="M12 3a5 5 0 00-5 5c0 1.5.7 2.8 1.8 3.7A5 5 0 0012 21a5 5 0 003.2-9.3A5 5 0 0012 3z" stroke="currentColor" stroke-width="1.6"/><path d="M9 10h6M9 14h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>`,
  },
  {
    name: "Plugins",
    blurb: "Marketplace extensions installed at the user level.",
    icon: `<path d="M10 3v4h4V3M4 10h4v4H4M21 10h-4v4h4M10 17v4h4v-4M8 7h8v10H8z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>`,
  },
  {
    name: "Conversations",
    blurb: "Every past Claude session, searchable and groupable by project.",
    icon: `<path d="M4 6h16v10H13l-4 3v-3H4V6z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M8 10h8M8 13h5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>`,
  },
];
---

<section id="kinds" class="relative py-32 md:py-40 border-t border-hairline">
  <div class="max-w-6xl mx-auto px-6">
    <div class="max-w-2xl">
      <div class="text-xs font-mono uppercase tracking-widest text-accent">What CCM manages</div>
      <h2 class="mt-3 text-4xl md:text-5xl font-bold tracking-tight text-balance">
        If Claude Code reads it, CCM edits it.
      </h2>
      <p class="mt-5 text-lg text-ink-300 text-pretty">
        Ten kinds of configuration, all in one place. Create, edit, and move
        them between projects without hunting for files.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-px bg-ink-800/60 border border-hairline rounded-2xl overflow-hidden">
      {kinds.map(({ name, blurb, icon }) => (
        <div class="group relative bg-ink-950 p-6 hover:bg-ink-900/60 transition-colors">
          <div class="flex items-center gap-3">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md bg-ink-900 border border-hairline text-accent group-hover:text-accent-soft transition-colors">
              <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4" set:html={icon} />
            </div>
            <h3 class="text-base font-semibold tracking-tight text-ink-100">{name}</h3>
          </div>
          <p class="mt-3 text-sm leading-relaxed text-ink-400 text-pretty">{blurb}</p>
        </div>
      ))}
    </div>
  </div>
</section>
