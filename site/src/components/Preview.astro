---
const shots = [
  {
    eyebrow: "Edit",
    title: "CodeMirror with live preview",
    body: "Markdown, YAML frontmatter, shiki-highlighted code fences. Edit on the left, see the rendered result on the right.",
  },
  {
    eyebrow: "Reference",
    title: "Click through the graph",
    body: "Every @-mention of an agent, command, or skill is a live link. Jump between related configs without leaving the app.",
  },
  {
    eyebrow: "Compare",
    title: "Diff user vs. project scope",
    body: "Promote a project agent to user scope or copy a user skill into a specific project — with a visual diff to confirm.",
  },
];
---

<section id="preview" class="relative py-24 md:py-32 border-t border-hairline">
  <div class="max-w-6xl mx-auto px-6">
    <div class="max-w-2xl">
      <div class="text-xs font-mono uppercase tracking-widest text-accent">Preview</div>
      <h2 class="mt-3 text-4xl md:text-5xl font-bold tracking-tight text-balance">
        A glimpse of the app.
      </h2>
      <p class="mt-5 text-lg text-ink-300 text-pretty">
        Polished screenshots coming soon. In the meantime, here's what you'll
        work with.
      </p>
    </div>

    <div class="mt-14 space-y-14">
      {shots.map(({ eyebrow, title, body }, i) => (
        <div class={`grid lg:grid-cols-5 gap-8 lg:gap-12 items-center ${i % 2 === 1 ? "lg:[&>*:first-child]:order-2" : ""}`}>
          <div class="lg:col-span-3">
            <div class="relative aspect-[16/10] rounded-xl border border-hairline bg-gradient-to-br from-ink-900 to-ink-950 overflow-hidden shadow-glow">
              <div class="absolute inset-0 bg-grid opacity-60"></div>
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="text-center">
                  <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-hairline bg-ink-900/80 text-[11px] font-mono text-ink-400">
                    <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
                    <span>Screenshot placeholder</span>
                  </div>
                </div>
              </div>
              <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-ink-950 to-transparent"></div>
            </div>
          </div>
          <div class="lg:col-span-2">
            <div class="text-xs font-mono uppercase tracking-widest text-accent">{eyebrow}</div>
            <h3 class="mt-2 text-2xl md:text-3xl font-semibold tracking-tight text-ink-100 text-balance">{title}</h3>
            <p class="mt-3 text-base text-ink-400 text-pretty leading-relaxed">{body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
